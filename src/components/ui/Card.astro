---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  image?: string;
  href?: string;
  github?: string;
  githubStars?: number;
  githubStarsUrl?: string;
}

const { title, description, tags = [], image, href, github, githubStars = 0, githubStarsUrl } = Astro.props;
const formattedStars = githubStars > 0
  ? new Intl.NumberFormat('en', { notation: githubStars >= 1000 ? 'compact' : 'standard', maximumFractionDigits: 1 }).format(githubStars)
  : '';
---

<div class="rounded-xl bg-[var(--color-card-bg)] border border-[var(--color-border)] overflow-hidden card-hover h-full flex flex-col">
  {image && (
    <div class="aspect-video overflow-hidden bg-[var(--color-border)]">
      <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" />
    </div>
  )}
  <div class="p-5 flex-1 flex flex-col">
    <h3 class="font-semibold text-lg leading-snug">
      {href ? (
        <a href={href} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">
          {title}
        </a>
      ) : title}
    </h3>
    <p class="mt-2 text-sm text-[var(--color-text-secondary)] flex-1">{description}</p>
    {githubStars > 0 && (
      <div class="mt-3 flex items-center gap-2 text-xs text-[var(--color-text-secondary)]">
        <a
          href={githubStarsUrl || (github ? `${github.replace(/\/$/, '')}/stargazers` : href)}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-border)]/30 px-2.5 py-1 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-colors"
          aria-label={`${title} GitHub stars`}
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.969.719 4.193a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" /></svg>
          <span>{formattedStars}</span>
        </a>
      </div>
    )}
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <span class="px-2 py-0.5 rounded-full text-xs bg-[var(--color-border)]/50 text-[var(--color-text-secondary)]">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
