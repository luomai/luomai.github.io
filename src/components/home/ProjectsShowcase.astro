---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'yaml';

const projectsDir = path.resolve(process.cwd(), 'src/content/projects');
let projects: any[] = [];

try {
  const dirs = fs.readdirSync(projectsDir).filter(d => fs.statSync(path.join(projectsDir, d)).isDirectory());
  for (const dir of dirs) {
    const indexPath = path.join(projectsDir, dir, 'index.md');
    if (!fs.existsSync(indexPath)) continue;
    const raw = fs.readFileSync(indexPath, 'utf-8');
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    if (!fmMatch) continue;

    const metadata = yaml.parse(fmMatch[1]) || {};
    const tags = Array.isArray(metadata.tags)
      ? metadata.tags
      : typeof metadata.tags === 'string'
        ? metadata.tags.split(',').map((t: string) => t.trim()).filter(Boolean)
        : [];
    const github = metadata.github || '';

    projects.push({
      title: metadata.title || dir,
      description: metadata.description || '',
      category: metadata.category || '',
      tags,
      github,
      github_stars: Number(metadata.github_stars) || 0,
      github_stars_url: metadata.github_stars_url || (github ? `${github.replace(/\/$/, '')}/stargazers` : ''),
      url: metadata.url || github,
      featured: metadata.featured === true,
      date: new Date(metadata.date || 0),
    });
  }
} catch {}

projects.sort((a, b) => {
  if (b.github_stars !== a.github_stars) return b.github_stars - a.github_stars;
  return b.date.getTime() - a.date.getTime();
});

const totalStars = projects.reduce((sum, p) => sum + (Number(p.github_stars) || 0), 0);

function formatStars(stars: number): string {
  if (!stars) return '';
  return new Intl.NumberFormat('en', { notation: stars >= 1000 ? 'compact' : 'standard', maximumFractionDigits: 1 }).format(stars);
}
---

<section id="projects" class="mt-12 scroll-mt-24 animate-on-scroll">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-4">
    <div>
      <p class="text-sm font-semibold text-[var(--color-accent)] mb-1">Open-source impact</p>
      <h2 class="text-2xl font-semibold">Research Software &amp; Projects</h2>
      <p class="text-[var(--color-text-secondary)] mt-1 max-w-2xl">
        Open-source systems and software artifacts that turn research ideas into reusable infrastructure.
      </p>
    </div>
    <div class="flex flex-wrap items-center justify-start sm:justify-end gap-2 text-xs text-[var(--color-text-secondary)]">
      <span class="rounded-full border border-[var(--color-border)] px-3 py-1">{projects.length} projects</span>
      <span class="rounded-full border border-[var(--color-border)] px-3 py-1">{formatStars(totalStars)} stars</span>
      <a href="/projects" class="text-sm text-[var(--color-accent)] hover:underline shrink-0">All projects &rarr;</a>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    {projects.map(project => (
      <article class="rounded-2xl bg-[var(--color-card-bg)] border border-[var(--color-border)] p-3 card-hover min-h-[10rem] flex flex-col">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <h3 class="font-semibold leading-snug">
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">
                  {project.title}
                </a>
              ) : project.title}
            </h3>
            {project.category && <p class="text-xs text-[var(--color-text-secondary)] mt-1">{project.category}</p>}
          </div>
          {project.github_stars > 0 && (
            <a
              href={project.github_stars_url}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 inline-flex items-center gap-1 rounded-full border border-[var(--color-border)] bg-[var(--color-border)]/30 px-2 py-0.5 text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-colors"
              aria-label={`${project.title} GitHub stars`}
            >
              <svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.969.719 4.193a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" /></svg>
              <span>{formatStars(project.github_stars)}</span>
            </a>
          )}
        </div>
        <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-snug flex-1">{project.description}</p>
        {project.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {project.tags.slice(0, 2).map((tag: string) => (
              <span class="px-2 py-0.5 rounded-full text-xs bg-[var(--color-border)]/50 text-[var(--color-text-secondary)]">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</section>
