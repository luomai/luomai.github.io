---
import BaseLayout from '@components/layout/BaseLayout.astro';
import { getConfig } from '@lib/config';
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'yaml';

const config = getConfig();
if (!config.pages.team) return Astro.redirect('/404');

let allMembers: any[] = [];
try {
  const teamPath = path.resolve(process.cwd(), 'src/content/team.yml');
  const data = yaml.parse(fs.readFileSync(teamPath, 'utf-8'));
  allMembers = (data.members || []).filter((m: any) => m.hidden !== true && m.display !== false);
} catch {}

const isAlumniOrCollaborator = (m: any) =>
  m.alumni ||
  m.group === 'alumni_collaborators' ||
  /collaborator/i.test(m.role || '');

const currentMembers = allMembers.filter((m: any) => !isAlumniOrCollaborator(m));
const alumniAndCollaborators = allMembers.filter(isAlumniOrCollaborator);

const currentSections = [
  {
    title: 'Postdocs & Research Staff',
    members: currentMembers.filter((m: any) => m.group === 'postdocs'),
  },
  {
    title: 'PhD Students',
    members: currentMembers.filter((m: any) => m.group === 'phd_students'),
  },
  {
    title: 'Other Current Members',
    members: currentMembers.filter((m: any) => !['postdocs', 'phd_students'].includes(m.group)),
  },
].filter(section => section.members.length > 0);
---

<BaseLayout title="Group" description="Large-Scale Machine Learning Systems Group members">
  <div class="animate-on-scroll">
    <h1 class="text-3xl font-bold mb-3">Group</h1>
    <p class="text-[var(--color-text-secondary)] mb-8 max-w-3xl">
      Members and alumni of the Large-Scale Machine Learning Systems Group.
    </p>
  </div>

  {currentSections.map(section => (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-6">{section.title}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {section.members.map((m: any) => (
          <div class="p-4 rounded-xl bg-[var(--color-card-bg)] border border-[var(--color-border)] text-center card-hover">
            <div class="w-20 h-20 mx-auto rounded-full bg-[var(--color-border)] overflow-hidden mb-3">
              {m.image ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-2xl text-[var(--color-text-secondary)]">{m.name[0]}</div>}
            </div>
            <h3 class="font-medium text-sm">{m.url ? <a href={m.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)]">{m.name}</a> : m.name}</h3>
            <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">{m.role}</p>
          </div>
        ))}
      </div>
    </section>
  ))}

  {alumniAndCollaborators.length > 0 && (
    <section>
      <h2 class="text-xl font-semibold mb-6">Alumni</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {alumniAndCollaborators.map((m: any) => (
          <div class="p-4 rounded-xl bg-[var(--color-card-bg)] border border-[var(--color-border)] text-center opacity-90">
            <div class="w-16 h-16 mx-auto rounded-full bg-[var(--color-border)] overflow-hidden mb-3">
              {m.image ? <img src={m.image} alt={m.name} class="w-full h-full object-cover" /> : <div class="w-full h-full flex items-center justify-center text-xl text-[var(--color-text-secondary)]">{m.name[0]}</div>}
            </div>
            <h3 class="font-medium text-sm">{m.url ? <a href={m.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)]">{m.name}</a> : m.name}</h3>
            <p class="text-xs text-[var(--color-text-secondary)]">{m.role}{m.year_left ? ` (${m.year_left})` : ''}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {allMembers.length === 0 && <p class="text-[var(--color-text-secondary)] text-center py-12">Add team members to src/content/team.yml.</p>}
</BaseLayout>
